def show_prefixes(asn):
    section("Prefixos Anunciados (RIPE Stat)")
    data = ripe_prefixes(asn); time.sleep(REQ_DELAY)
    if not data or not data.get("data"):
        print(red("  Sem dados de prefixos.")); return

    pfxs = data["data"].get("prefixes", [])
    v4 = sorted([p for p in pfxs if ":" not in p.get("prefix","")], key=lambda x: x["prefix"])
    v6 = sorted([p for p in pfxs if ":" in  p.get("prefix","")],    key=lambda x: x["prefix"])

    if v4:
        rows = [[cyan(p["prefix"]), gray(str(round(p.get("timelines",[{}])[-1].get("endtime","")[:10] if p.get("timelines") else "","")))]
                for p in v4]
        # simplifica: só prefixo
        rows = [[cyan(p["prefix"])] for p in v4]
        print(bold(f"\n  IPv4 — {len(v4)} prefixo(s)"))
        print(table(rows, headers=[bold("Prefixo")]))
    if v6:
        rows = [[cyan(p["prefix"])] for p in v6]
        print(bold(f"\n  IPv6 — {len(v6)} prefixo(s)"))
        print(table(rows, headers=[bold("Prefixo")]))
    if not v4 and not v6:
        print(gray("  Nenhum prefixo encontrado."))


def show_neighbours(asn):
    data = ripe_neighbours(asn); time.sleep(REQ_DELAY)
    if not data or not data.get("data"): return

    nb    = data["data"].get("neighbours", [])
    ups   = [n for n in nb if n.get("type") == "left"]
    dns   = [n for n in nb if n.get("type") == "right"]
    peers = [n for n in nb if n.get("type") == "uncertain"]

    if ups:
        section(f"Upstream Providers (RIPE Stat) — {len(ups)}")
        rows = [[f"AS{n['asn']}", gray(str(n.get('power','')))]
                for n in sorted(ups, key=lambda x: x.get('asn',0))]
        print(table(rows, headers=[bold("ASN"), bold("Peso")]))

    if dns:
        section(f"Downstream Customers (RIPE Stat) — {len(dns)}")
        rows = [[f"AS{n['asn']}", gray(str(n.get('power','')))]
                for n in sorted(dns, key=lambda x: x.get('asn',0))]
        print(table(rows, headers=[bold("ASN"), bold("Peso")]))

    if peers:
        section(f"Peers (RIPE Stat) — {len(peers)}")
        rows = [[f"AS{n['asn']}"] for n in sorted(peers, key=lambda x: x.get('asn',0))[:40]]
        print(table(rows, headers=[bold("ASN")]))
        if len(peers) > 40: print(gray(f"  ... e mais {len(peers)-40} peers"))


def show_ixs(pdb, net_id):
    section("Internet Exchanges (PeeringDB)")
    if not pdb or not net_id:
        print(gray("  ASN não encontrado no PeeringDB.")); return

    ixlans = pdb.get("netixlan_set", []) or pdb_netixlan(net_id)
    if not ixlans:
        print(gray("  Nenhum IX encontrado.")); return

    ix_map = {}
    for e in ixlans:
        ix_id = e.get("ix_id") or e.get("ixlan_id")
        if ix_id not in ix_map:
            ix_map[ix_id] = {"name":e.get("name","") or f"IX-{ix_id}",
                              "speed":0, "ipv4":[], "ipv6":[],
                              "rs":e.get("is_rs_peer",False),
                              "bfd":e.get("bfd_support",False),
                              "op":e.get("operational",True)}
        if e.get("ipaddr4"): ix_map[ix_id]["ipv4"].append(e["ipaddr4"])
        if e.get("ipaddr6"): ix_map[ix_id]["ipv6"].append(e["ipaddr6"])
        if e.get("speed",0) > ix_map[ix_id]["speed"]: ix_map[ix_id]["speed"] = e["speed"]

    rows = []
    for d in sorted(ix_map.values(), key=lambda x: x["name"]):
        op  = green("●") if d["op"]  else red("●")
        rs  = green("RS")  if d["rs"]  else gray("—")
        bfd = green("BFD") if d["bfd"] else gray("—")
        rows.append([f"{op} {bold(d['name'][:38])}", cyan(fmt_speed(d["speed"])),
                     "\n".join(d["ipv4"]) or DASH, "\n".join(d["ipv6"]) or DASH, rs, bfd])
    print(table(rows, headers=[bold("Internet Exchange"), bold("Velocidade"),
                                bold("IPv4"), bold("IPv6"), bold("RS"), bold("BFD")]))
    print(gray(f"\n  Total: {len(ix_map)} IX(s)"))


def show_facilities(pdb, net_id):
