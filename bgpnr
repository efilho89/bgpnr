def show_neighbours(asn, _data=None):
    data = _data if _data is not None else ripe_neighbours(asn)
    if not data or not data.get("data"): return

    nb    = data["data"].get("neighbours",[])
    ups   = sorted([n for n in nb if n.get("type")=="left"],      key=lambda x: -x.get("power",0))
    dns   = sorted([n for n in nb if n.get("type")=="right"],     key=lambda x: -x.get("power",0))
    peers = sorted([n for n in nb if n.get("type")=="uncertain"], key=lambda x:  x.get("asn",0))

    DETAIL = 12  # top N com nome completo

    def fetch_holder(asn_n):
        d = get(f"{RIPE_API}/as-overview/data.json", {"resource": f"AS{asn_n}"})
        return ((d or {}).get("data",{}) or {}).get("holder","") or ""

    def compact_grid(items, color_fn, ncols=5):
        w = 14; bar = f"{C.GRY}│{C.RST}"
        rows = [items[i:i+ncols] for i in range(0, len(items), ncols)]
        print(f"  {C.GRY}┌{'┬'.join('─'*(w+2) for _ in range(ncols))}┐{C.RST}")
        for row in rows:
            cells = [color_fn(f"AS{n['asn']}") + " "*max(0, w-vlen(color_fn(f"AS{n['asn']}"))) for n in row]
            while len(cells) < ncols: cells.append(" "*w)
            print(f"  {bar}" + bar.join(f" {c} " for c in cells) + bar)
        print(f"  {C.GRY}└{'┴'.join('─'*(w+2) for _ in range(ncols))}┘{C.RST}")

    def show_group(items, label, icon, col, asn_fn):
        if not items: return
        section(f"{label}  ({len(items)})", icon, col)
        print()
        top  = items[:DETAIL]
        rest = items[DETAIL:]

        # Busca nomes em paralelo para o top N
        sys.stdout.write(f"  {gray('Buscando nomes...')}\r")
        sys.stdout.flush()
        with ThreadPoolExecutor(max_workers=DETAIL) as ex:
            futs = {n["asn"]: ex.submit(fetch_holder, n["asn"]) for n in top}
            names = {a: f.result() for a, f in futs.items()}
        sys.stdout.write(" " * 30 + "\r")

        rows = []
        for n in top:
            nm = names.get(n["asn"],"") or f"AS{n['asn']}"
            v4 = green("✔") if n.get("v4_peers",0) > 0 else red("✘")
            v6 = green("✔") if n.get("v6_peers",0) > 0 else red("✘")
            rows.append([asn_fn(f"AS{n['asn']}"), bold(white(nm[:50])), v4, v6])
        print(vtable(rows,
            headers=[gray("ASN"), gray("Nome / Holder"), gray("IPv4"), gray("IPv6")],
            color=col, hcolor=col))

        if rest:
            print(f"\n  {gray(f'  +{len(rest)} adicionais:')}")
            compact_grid(rest, lambda s: gray(s))
        print()

    show_group(ups,  "Upstream Providers",   "▲", C.BLU, lambda s: bold(blue(s)))
    show_group(dns,  "Downstream Customers", "▼", C.GRN, lambda s: bold(green(s)))

    if peers:
        shown = peers[:60]
        section(f"Peers  ({len(peers)})", "↔", C.GRY)
        print()
        compact_grid(shown, lambda s: gray(s), ncols=6)
        if len(peers) > 60: print(gray(f"\n  ... e mais {len(peers)-60} peers"))
        print()


