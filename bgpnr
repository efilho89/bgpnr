def show_prefixes(asn):
    section("Prefixos Anunciados", "⬡", C.MAG)
    data = ripe_prefixes(asn); time.sleep(REQ_DELAY)
    if not data or not data.get("data"):
        print(red("  Sem dados de prefixos.")); return

    pfxs = data["data"].get("prefixes",[])
    v4 = sorted([p for p in pfxs if ":" not in p.get("prefix","")], key=lambda x: x["prefix"])
    v6 = sorted([p for p in pfxs if ":" in  p.get("prefix","")],    key=lambda x: x["prefix"])

    for label, plist, col_w, ncols in [("IPv4", v4, 20, 3), ("IPv6", v6, 26, 2)]:
        if not plist: continue
        print(f"\n  {C.BOLD}{C.MAG}  {label}  {C.RST}{gray(f'{len(plist)} prefixo(s)')}")
        # tabela com bordas
        rows_grid = [plist[i:i+ncols] for i in range(0, len(plist), ncols)]
        widths = [col_w] * ncols
        print(f"  {C.MAG}┌{'┬'.join('─'*(w+2) for w in widths)}┐{C.RST}")
        for row in rows_grid:
            cells = [cyan(p["prefix"]) + " " * max(0, col_w - len(p["prefix"])) for p in row]
            while len(cells) < ncols:
                cells.append(" " * col_w)
            bar = f"{C.MAG}│{C.RST}"
            print(f"  {bar}" + bar.join(f" {c} " for c in cells) + bar)
        print(f"  {C.MAG}└{'┴'.join('─'*(w+2) for w in widths)}┘{C.RST}")

    if not v4 and not v6:
        print(gray("  Nenhum prefixo encontrado."))
    print()


def show_neighbours(asn):
    data = ripe_neighbours(asn); time.sleep(REQ_DELAY)
    if not data or not data.get("data"): return

    nb    = data["data"].get("neighbours",[])
    ups   = sorted([n for n in nb if n.get("type")=="left"],      key=lambda x: -x.get("power",0))
    dns   = sorted([n for n in nb if n.get("type")=="right"],     key=lambda x: -x.get("power",0))
    peers = sorted([n for n in nb if n.get("type")=="uncertain"], key=lambda x:  x.get("asn",0))

    def asn_grid(items, fn, ncols=5):
        w = 14
        rows = [items[i:i+ncols] for i in range(0, len(items), ncols)]
        bar = f"{C.GRY}│{C.RST}"
        widths = [w] * ncols
        print(f"  {C.GRY}┌{'┬'.join('─'*(w+2) for _ in widths)}┐{C.RST}")
        for row in rows:
            cells = [fn(n) + " " * max(0, w - vlen(fn(n))) for n in row]
            while len(cells) < ncols: cells.append(" " * w)
            print(f"  {bar}" + bar.join(f" {c} " for c in cells) + bar)
        print(f"  {C.GRY}└{'┴'.join('─'*(w+2) for _ in widths)}┘{C.RST}")

    if ups:
        section(f"Upstream Providers  ({len(ups)})", "▲", C.BLU)
        print()
        asn_grid(ups, lambda n: bold(blue(f"AS{n['asn']}")))
        print()

    if dns:
        section(f"Downstream Customers  ({len(dns)})", "▼", C.GRN)
        print()
        asn_grid(dns, lambda n: bold(green(f"AS{n['asn']}")))
        print()

    if peers:
        shown = peers[:50]
        section(f"Peers  ({len(peers)})", "↔", C.GRY)
        print()
        asn_grid(shown, lambda n: gray(f"AS{n['asn']}"), ncols=6)
        if len(peers) > 50: print(gray(f"\n  ... e mais {len(peers)-50} peers"))
        print()


