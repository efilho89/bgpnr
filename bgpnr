def show_prefixes(asn, _data=None, _rpki_data=None):
    section("Prefixos Anunciados", "⬡", C.MAG)
    data = _data if _data is not None else ripe_prefixes(asn)
    if not data or not data.get("data"):
        print(red("  Sem dados de prefixos.")); return

    pfxs = data["data"].get("prefixes",[])
    v4 = sorted([p for p in pfxs if ":" not in p.get("prefix","")], key=lambda x: x["prefix"])
    v6 = sorted([p for p in pfxs if ":" in  p.get("prefix","")],    key=lambda x: x["prefix"])

    # Monta lookup RPKI { prefix: {status, irr} } a partir do routing-consistency
    rpki_lk = {}
    if _rpki_data and _rpki_data.get("data"):
        for p in _rpki_data["data"].get("prefixes", []):
            rpki_lk[p["prefix"]] = {
                "status": p.get("rpki_status","not_found"),
                "irr":    ", ".join(p.get("irr_sources",[])) or DASH,
            }

    def rpki_cell(prefix):
        st = rpki_lk.get(prefix, {}).get("status","not_found")
        if   st == "valid":   return bold(green("✔ VALID"))
        elif st == "invalid": return bold(red("✘ INVALID"))
        else:                 return yellow("? NOT FOUND")

    for label, plist in [("IPv4", v4), ("IPv6", v6)]:
        if not plist: continue
        print(f"\n  {C.BOLD}{C.MAG}  {label}{C.RST}  {gray(f'{len(plist)} prefixo(s)')}")

        if rpki_lk:
            # Tabela com colunas RPKI e IRR inline
            rows = []
            for p in plist:
                ri  = rpki_lk.get(p["prefix"], {})
                irr = ri.get("irr", DASH)
                rows.append([cyan(p["prefix"]), rpki_cell(p["prefix"]), gray(irr[:24])])
            print(vtable(rows,
                headers=[gray("Prefixo"), gray("RPKI"), gray("IRR / Fonte")],
                color=C.MAG, hcolor=C.MAG))
        else:
            # Grid simples quando não há dados RPKI
            ncols = 3 if label == "IPv4" else 2
            col_w = 20 if label == "IPv4" else 26
            rows_grid = [plist[i:i+ncols] for i in range(0, len(plist), ncols)]
            widths = [col_w] * ncols
            print(f"  {C.MAG}┌{'┬'.join('─'*(w+2) for w in widths)}┐{C.RST}")
            for row in rows_grid:
                cells = [cyan(p["prefix"]) + " " * max(0, col_w - len(p["prefix"])) for p in row]
                while len(cells) < ncols: cells.append(" " * col_w)
                bar = f"{C.MAG}│{C.RST}"
                print(f"  {bar}" + bar.join(f" {c} " for c in cells) + bar)
            print(f"  {C.MAG}└{'┴'.join('─'*(w+2) for w in widths)}┘{C.RST}")

    if not v4 and not v6:
        print(gray("  Nenhum prefixo encontrado."))
    print()


def show_rpki_irr(asn, _data=None):
    section("RPKI  /  IRR Consistency", "⚑", C.RED)
    data = _data if _data is not None else ripe_routing_consistency(asn)
    if not data or not data.get("data"):
        print(gray("  Sem dados de RPKI/IRR disponíveis.")); print(); return

    pfxs = data["data"].get("prefixes", [])
    if not pfxs:
        print(gray("  Nenhum prefixo encontrado.")); print(); return

    v4 = sorted([p for p in pfxs if ":" not in p.get("prefix","")], key=lambda x: x["prefix"])
    v6 = sorted([p for p in pfxs if ":" in  p.get("prefix","")],    key=lambda x: x["prefix"])

    def rpki_badge(st):
        if   st == "valid":   return bold(green("✔ VALID"))
        elif st == "invalid": return bold(red("✘ INVALID"))
        else:                 return yellow("? NOT FOUND")

    for label, plist in [("IPv4", v4), ("IPv6", v6)]:
        if not plist: continue
        total   = len(plist)
        valid   = sum(1 for p in plist if p.get("rpki_status") == "valid")
        invalid = sum(1 for p in plist if p.get("rpki_status") == "invalid")
        nfound  = total - valid - invalid
        no_irr  = sum(1 for p in plist if not p.get("in_whois"))
        not_bgp = sum(1 for p in plist if not p.get("in_bgp"))
        cov     = int(valid / total * 100) if total else 0

        if cov == 100:   cov_str = bold(green(f"{cov}%"))
        elif cov >= 50:  cov_str = bold(yellow(f"{cov}%"))
        else:            cov_str = bold(red(f"{cov}%"))

        print(f"\n  {C.BOLD}{C.RED}  {label}{C.RST}  {gray(f'— {total} prefixo(s)')}")
        line = f"    {gray('RPKI  :')}  {green(f'✔ {valid} válidos')}"
        if invalid: line += f"  {red(f'✘ {invalid} inválidos  ← ATENÇÃO')}"
        if nfound:  line += f"  {yellow(f'? {nfound} sem ROA')}"
        else:       line += f"  {green('✔ todos com ROA')}"
        line += f"    {gray('Cobertura:')} {cov_str}"
        print(line)
        if no_irr:
            print(f"    {gray('IRR   :')}  {yellow(f'⚠  {no_irr} prefixo(s) sem route object no IRR / WHOIS')}")
        if not_bgp:
            print(f"    {gray('BGP   :')}  {gray(f'○  {not_bgp} registrado(s) no IRR mas não anunciado no BGP')}")
        print()

        rows = []
        for p in plist:
            st    = p.get("rpki_status", "not_found")
            irr   = ", ".join(p.get("irr_sources", [])) or DASH
            b_bgp = green("✔") if p.get("in_bgp")   else red("✘")
            b_irr = green("✔") if p.get("in_whois") else red("✘")
            rows.append([cyan(p["prefix"]), rpki_badge(st), white(irr[:28]), b_bgp, b_irr])

        print(vtable(rows, headers=[
            gray("Prefixo"), gray("RPKI Status"), gray("IRR / Fonte"), gray("BGP"), gray("IRR")
        ], color=C.RED, hcolor=C.RED))
        print()


def show_abuse(asn, _data=None):
    data = _data if _data is not None else ripe_abuse_contact(asn)
    if not data: return
