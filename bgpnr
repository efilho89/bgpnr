# ── Trânsito IP vs IXs ───────────────────────────────────────────────────────

def transit_vs_ix(asn):
    """
    Mostra os provedores de trânsito (upstreams) do ASN e verifica
    quais deles também estão presentes nos mesmos IXs — oportunidade
    de peering direto para substituir ou complementar o trânsito.
    """
    print(f"\n  Analisando trânsito IP e IXs de {bold(cyan(f'AS{asn}'))} ...\n")

    # 1. Upstreams via RIPE Stat
    nb_data = ripe_neighbours(asn); time.sleep(REQ_DELAY)
    if not nb_data or not nb_data.get("data"):
        print(red("  Sem dados de neighbours no RIPE Stat.")); return

    ups = [n for n in nb_data["data"].get("neighbours",[]) if n.get("type") == "left"]
    if not ups:
        print(gray("  Nenhum upstream encontrado no RIPE Stat.")); return

    upstream_asns = [n["asn"] for n in ups]

    # 2. IXs do ASN principal via PeeringDB
    pdb_main = pdb_net(asn); time.sleep(REQ_DELAY)
    if not pdb_main:
        print(red("  ASN não encontrado no PeeringDB.")); return

    ixlans_main = pdb_main.get("netixlan_set") or pdb_netixlan(pdb_main["id"]); time.sleep(REQ_DELAY)
    if not ixlans_main:
        print(gray("  ASN não presente em nenhum IX no PeeringDB.")); return

    name_main = pdb_main.get("name","") or f"AS{asn}"

    # Mapeia ix_id → dados do ASN principal
    def build_map(ixlans):
        m = {}
        for e in ixlans:
            ix_id = e.get("ix_id") or e.get("ixlan_id")
            if ix_id not in m:
                m[ix_id] = {"name": e.get("name","") or f"IX-{ix_id}",
                             "speed":0, "ipv4":[], "ipv6":[], "rs":e.get("is_rs_peer",False)}
            if e.get("ipaddr4"): m[ix_id]["ipv4"].append(e["ipaddr4"])
            if e.get("ipaddr6"): m[ix_id]["ipv6"].append(e["ipaddr6"])
            if e.get("speed",0) > m[ix_id]["speed"]: m[ix_id]["speed"] = e["speed"]
        return m

    map_main = build_map(ixlans_main)

    print(f"  {bold(green(name_main))} presente em {bold(str(len(map_main)))} IX(s)")
    print(f"  Verificando {bold(str(len(upstream_asns)))} upstream(s) no PeeringDB ...\n")

    results_common = []   # upstreams que compartilham IX
    results_none   = []   # upstreams sem IX em comum
    results_nopdb  = []   # upstreams não encontrados no PeeringDB

    for up_asn in sorted(upstream_asns):
        pdb_up = pdb_net(up_asn); time.sleep(REQ_DELAY)
        if not pdb_up:
            results_nopdb.append(up_asn); continue

        up_name = pdb_up.get("name","") or f"AS{up_asn}"
        ixlans_up = pdb_up.get("netixlan_set") or pdb_netixlan(pdb_up["id"]); time.sleep(REQ_DELAY)
        if not ixlans_up:
            results_none.append({"asn": up_asn, "name": up_name, "reason": "Não presente em IXs"}); continue

        map_up = build_map(ixlans_up)
        common = set(map_main.keys()) & set(map_up.keys())

        if not common:
            results_none.append({"asn": up_asn, "name": up_name,
                                  "reason": f"Em {len(map_up)} IX(s), nenhum em comum"}); continue

        results_common.append({
            "asn": up_asn, "name": up_name,
            "common": common, "map_up": map_up,
        })

    # ── Resultado: upstreams com IX em comum ──────────────────────────────────
    if results_common:
        section(f"Oportunidades de Peering Direto — {len(results_common)} upstream(s) no mesmo IX")
        print(gray("  Estes provedores de trânsito estão presentes nos mesmos IXs que você.\n"
                   "  Considere negociar peering gratuito (settlement-free) com eles.\n"))

        for r in results_common:
            up_asn, up_name = r["asn"], r["name"]
            n_common = len(r["common"])
            print(f"  {bold(green(f'AS{up_asn}'))}  {bold(up_name)}  {gray(f'— {n_common} IX(s) em comum')}")

            rows = []
            for ix_id in sorted(r["common"], key=lambda x: map_main[x]["name"]):
                d_me = map_main[ix_id]
                d_up = r["map_up"][ix_id]
                rs_me = green("RS") if d_me["rs"] else gray("—")
                rs_up = green("RS") if d_up["rs"] else gray("—")
                rows.append([
                    bold(d_me["name"][:35]),
                    cyan(fmt_speed(d_me["speed"])), cyan(fmt_speed(d_up["speed"])),
                    "\n".join(d_me["ipv4"]) or DASH, "\n".join(d_up["ipv4"]) or DASH,
                    "\n".join(d_me["ipv6"]) or DASH, "\n".join(d_up["ipv6"]) or DASH,
                    rs_me, rs_up,
                ])
            print(table(rows, headers=[
                bold("IX"),
                bold(f"Vel AS{asn}"), bold(f"Vel AS{up_asn}"),
                bold(f"IPv4 AS{asn}"), bold(f"IPv4 AS{up_asn}"),
                bold(f"IPv6 AS{asn}"), bold(f"IPv6 AS{up_asn}"),
                bold("RS meu"), bold("RS trânsito"),
            ]))
            print()

    # ── Upstreams sem IX em comum ─────────────────────────────────────────────
    if results_none:
        section(f"Upstreams sem IX em Comum — {len(results_none)}")
        rows = [[f"AS{r['asn']}", bold(r['name'][:42]), gray(r['reason'])]
                for r in results_none]
        print(table(rows, headers=[bold("ASN"), bold("Nome"), bold("Situação")]))

    # ── Upstreams não no PeeringDB ────────────────────────────────────────────
    if results_nopdb:
        section(f"Upstreams não encontrados no PeeringDB — {len(results_nopdb)}")
        rows = [[f"AS{a}"] for a in results_nopdb]
        print(table(rows, headers=[bold("ASN")]))

    print()
    print(gray("  Fontes: RIPE Stat (neighbours) + PeeringDB (IXs)"))
    print()


# ── Comparação de IXs entre dois ASNs ────────────────────────────────────────

def compare_ixs(asn1, asn2):
    print(f"\n  Buscando IXs em comum entre {bold(cyan(f'AS{asn1}'))} e {bold(cyan(f'AS{asn2}'))} ...\n")

    pdb1 = pdb_net(asn1); time.sleep(REQ_DELAY)
    pdb2 = pdb_net(asn2); time.sleep(REQ_DELAY)

    name1 = (pdb1.get("name","") if pdb1 else "") or f"AS{asn1}"
    name2 = (pdb2.get("name","") if pdb2 else "") or f"AS{asn2}"

    if not pdb1 or not pdb2:
        print(red("  Um ou ambos os ASNs não encontrados no PeeringDB.")); return

    ixlans1 = pdb1.get("netixlan_set") or pdb_netixlan(pdb1["id"]); time.sleep(REQ_DELAY)
    ixlans2 = pdb2.get("netixlan_set") or pdb_netixlan(pdb2["id"]); time.sleep(REQ_DELAY)

    def build_map(ixlans):
        m = {}
        for e in ixlans:
            ix_id = e.get("ix_id") or e.get("ixlan_id")
            if ix_id not in m:
                m[ix_id] = {"name":e.get("name","") or f"IX-{ix_id}",
                             "speed":0, "ipv4":[], "ipv6":[], "rs":e.get("is_rs_peer",False)}
            if e.get("ipaddr4"): m[ix_id]["ipv4"].append(e["ipaddr4"])
            if e.get("ipaddr6"): m[ix_id]["ipv6"].append(e["ipaddr6"])
            if e.get("speed",0) > m[ix_id]["speed"]: m[ix_id]["speed"] = e["speed"]
        return m

    map1 = build_map(ixlans1)
    map2 = build_map(ixlans2)
    common = set(map1.keys()) & set(map2.keys())

    print(f"  {bold(green(name1))} {gray(f'(AS{asn1})')}  →  {bold(str(len(map1)))} IXs")
    print(f"  {bold(green(name2))} {gray(f'(AS{asn2})')}  →  {bold(str(len(map2)))} IXs")
    print()

    if not common:
        print(red(f"  Nenhum IX em comum encontrado."))
        print(gray("  Os dois ASNs não compartilham nenhum ponto de troca no PeeringDB."))
        return

    section(f"IXs em Comum ({len(common)}) — AS{asn1} ↔ AS{asn2}")
    rows = []
    for ix_id in sorted(common, key=lambda x: map1[x]["name"]):
        d1, d2 = map1[ix_id], map2[ix_id]
        rs1 = green("RS") if d1["rs"] else gray("—")
        rs2 = green("RS") if d2["rs"] else gray("—")
        rows.append([
            bold(d1["name"][:35]),
            cyan(fmt_speed(d1["speed"])), cyan(fmt_speed(d2["speed"])),
            "\n".join(d1["ipv4"]) or DASH, "\n".join(d2["ipv4"]) or DASH,
            "\n".join(d1["ipv6"]) or DASH, "\n".join(d2["ipv6"]) or DASH,
            rs1, rs2,
        ])
    print(table(rows, headers=[
        bold("IX"),
        bold(f"Vel AS{asn1}"), bold(f"Vel AS{asn2}"),
        bold(f"IPv4 AS{asn1}"), bold(f"IPv4 AS{asn2}"),
        bold(f"IPv6 AS{asn1}"), bold(f"IPv6 AS{asn2}"),
        bold(f"RS {asn1}"), bold(f"RS {asn2}"),
    ]))

    only1 = set(map1.keys()) - common
    only2 = set(map2.keys()) - common

    if only1:
        section(f"Exclusivos de AS{asn1} ({name1}) — {len(only1)}")
        rows = [[bold(map1[ix]["name"][:48]), cyan(fmt_speed(map1[ix]["speed"]))]
                for ix in sorted(only1, key=lambda x: map1[x]["name"])]
        print(table(rows, headers=[bold("Internet Exchange"), bold("Velocidade")]))

    if only2:
        section(f"Exclusivos de AS{asn2} ({name2}) — {len(only2)}")
        rows = [[bold(map2[ix]["name"][:48]), cyan(fmt_speed(map2[ix]["speed"]))]
                for ix in sorted(only2, key=lambda x: map2[x]["name"])]
        print(table(rows, headers=[bold("Internet Exchange"), bold("Velocidade")]))

    print()
    print(gray("  Fonte: PeeringDB (peeringdb.com)"))
    print()


# ── Busca por nome ────────────────────────────────────────────────────────────

def search_and_select(query):
    print(f"\n  Buscando por {bold(yellow(query))} ...\n")
    results = []

    pdb = pdb_search(query); time.sleep(REQ_DELAY)
    if pdb:
        for item in pdb:
            if item.get("asn"):
                results.append({"asn":item["asn"],"name":item.get("name",""),
                                 "desc":item.get("aka",""),"src":"PeeringDB"})

    if not results:
        print(red("  Nenhum resultado encontrado.")); sys.exit(1)

    rows = [[i+1, f"AS{r['asn']}", bold(r['name'][:42]), r['desc'][:30], gray(r['src'])]
            for i,r in enumerate(results)]
    print(table(rows, headers=[bold("#"), bold("ASN"), bold("Nome"), bold("Descrição"), bold("Fonte")]))
    print()
    try:
        choice = input(f"  {bold('Selecione o número')} (Enter para cancelar): ").strip()
        if not choice: sys.exit(0)
        idx = int(choice)-1
        if 0 <= idx < len(results): return results[idx]["asn"]
        print(red("  Opção inválida.")); sys.exit(1)
    except (ValueError, KeyboardInterrupt):
        print(); sys.exit(0)


# ── Main ──────────────────────────────────────────────────────────────────────

def run(asn_or_name):
    clean = str(asn_or_name).strip().upper().lstrip("AS")
    asn   = int(clean) if clean.isdigit() else search_and_select(str(asn_or_name).strip())
    if not asn: print(red("  ASN inválido.")); sys.exit(1)

    print(f"\n  Consultando {bold(cyan(f'AS{asn}'))} ...\n")
    pdb     = pdb_net(asn);       time.sleep(REQ_DELAY)
    ripe_ov = ripe_overview(asn); time.sleep(REQ_DELAY)
    net_id  = pdb.get("id") if pdb else None

    show_header(asn, pdb, ripe_ov)
    show_policy(pdb)
    show_contacts(pdb)
    show_prefixes(asn)
    show_neighbours(asn)
    show_ixs(pdb, net_id)
    show_facilities(pdb, net_id)

    print()
    print(gray("  Fontes: RIPE Stat (stat.ripe.net) + PeeringDB (peeringdb.com)"))
    if PEERINGDB_KEY: print(gray("  PeeringDB: autenticado com API Key"))
    else: print(gray("  Dica: export PEERINGDB_API_KEY=<chave>  para acesso autenticado"))
    print()


def interactive():
    print(f"""
  {bold(cyan('bgpnr'))} {gray('─')} BGP Network Recon v2.1
  {gray('Fontes: RIPE Stat + PeeringDB')}

  {bold('bgpnr 13335')}               → consulta ASN
  {bold('bgpnr Cloudflare')}          → busca por nome
  {bold('bgpnr --compare 1234 5678')} → IXs em comum entre dois ASNs
  {bold('bgpnr --transit 1234')}      → trânsito IP vs IXs (oportunidades de peering)
  {gray('Ctrl+C para sair')}
""")
    try:
        query = input(f"  {bold('ASN / Organização')}: ").strip()
    except KeyboardInterrupt:
        print(); sys.exit(0)
    if not query: sys.exit(0)
    run(query)


if __name__ == "__main__":
    try:
        args = sys.argv[1:]
        if not args:
            interactive()
        elif args[0] in ("-h","--help"):
            print(f"\n  bgpnr <ASN|nome>                  consulta ASN")
            print(f"  bgpnr --compare <ASN1> <ASN2>     IXs em comum entre dois ASNs")
            print(f"  bgpnr --transit <ASN>             trânsito IP vs IXs (peering opportunities)\n")
        elif args[0] in ("--compare","-c","compare") and len(args) >= 3:
            a1 = int(str(args[1]).upper().lstrip("AS"))
            a2 = int(str(args[2]).upper().lstrip("AS"))
            compare_ixs(a1, a2)
        elif args[0] in ("--transit","-t","transit") and len(args) >= 2:
            a1 = int(str(args[1]).upper().lstrip("AS"))
            transit_vs_ix(a1)
        else:
            run(" ".join(args))
    except KeyboardInterrupt:
        print(f"\n{gray('  Interrompido.')}\n"); sys.exit(0)
