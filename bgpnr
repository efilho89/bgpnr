def show_header(asn, pdb, ripe_ov):
    rov       = (ripe_ov or {}).get("data",{})
    name      = (pdb.get("name") if pdb else "") or rov.get("holder","") or DASH
    name_long = (pdb.get("name_long","") if pdb else "")
    country   = ((pdb.get("org") or {}).get("country","") if pdb else "") or ""
    website   = (pdb.get("website","") if pdb else "") or ""
    rir       = (pdb.get("rir_status","") if pdb else "") or ""

    section(f"AS{asn}  —  {ANSI.sub('',name)}", "◈", C.CYN)
    print()

    # ── Tabela de 2 colunas com divisor vertical ──────────────────────────────
    left = [
        (gray("ASN"),         bold(cyan(f"AS{asn}"))),
        (gray("Nome"),        bold(green(name))),
    ]
    if name_long and name_long != name:
        left.append((gray("Nome longo"), white(name_long)))
    if pdb and pdb.get("aka"):
        left.append((gray("Conhecido"), gray(pdb["aka"])))
    left += [
        (gray("País"),    white(country) if country else DASH),
        (gray("RIR"),     white(rir)     if rir     else DASH),
        (gray("Website"), blue(website)  if website else DASH),
    ]

    right = []
    if pdb:
        right += [
            (gray("Tipo"),       yellow(na(pdb.get("info_type")))),
            (gray("Escopo"),     white(na(pdb.get("info_scope")))),
            (gray("Tráfego"),    cyan(na(pdb.get("info_traffic")))),
            (gray("Ratio"),      white(na(pdb.get("info_ratio")))),
            (gray("IPv6"),       yes_no(pdb.get("info_ipv6"))),
            (gray("Multicast"),  yes_no(pdb.get("info_multicast"))),
            (gray("IXs"),        bold(cyan(str(pdb["ix_count"])))    if pdb.get("ix_count")  else DASH),
            (gray("Facilities"), bold(cyan(str(pdb["fac_count"])))   if pdb.get("fac_count") else DASH),
        ]
        if pdb.get("irr_as_set"):
            right.append((gray("IRR AS-Set"),    magenta(pdb["irr_as_set"])))
        if pdb.get("looking_glass"):
            right.append((gray("Looking Glass"), blue(pdb["looking_glass"][:40])))

    # Larguras fixas para as colunas
    kw, vw = 14, 32   # key width, value width
    lw = kw + vw + 5  # total largura coluna esquerda
    rw = kw + vw + 5  # total largura coluna direita
    div = f"{C.GRY}│{C.RST}"

    rows_n = max(len(left), len(right))
    # cabeçalho
    print(f"  {C.GRY}┌{'─'*(lw)}┬{'─'*(rw)}┐{C.RST}")

    for i in range(rows_n):
        lk, lv = left[i]  if i < len(left)  else ("", "")
        rk, rv = right[i] if i < len(right) else ("", "")

        def cell(k, v):
            ks = ANSI.sub("", str(k)); vs = ANSI.sub("", str(v))
            kp = str(k) + " " * max(0, kw - len(ks))
            vp = str(v) + " " * max(0, vw - len(vs))
            return f" {kp}  {vp} "

        lc = cell(lk, lv)
        rc = cell(rk, rv)
        print(f"  {C.GRY}│{C.RST}{lc}{div}{rc}{C.GRY}│{C.RST}")

    print(f"  {C.GRY}└{'─'*(lw)}┴{'─'*(rw)}┘{C.RST}")
    print()


def show_policy(pdb):
    if not pdb: return
    fields = [
        ("Política geral",     pdb.get("policy_general","")),
        ("URL da política",    pdb.get("policy_url","")),
        ("Restrição local",    pdb.get("policy_locations","")),
        ("Restrição ratio",    pdb.get("policy_ratio","")),
        ("Contratos",          pdb.get("policy_contracts","")),
    ]
    never_rs = pdb.get("info_never_via_route_servers", False)
    if not any(v for _,v in fields) and not never_rs: return

    section("Política de Peering", "⚖", C.YLW)
    print()
    rows = []
    for k, v in fields:
        if v:
            val = yellow(v) if k == "Política geral" else white(v)
            rows.append([gray(k), val])
    rows.append([gray("Nunca via RS"), yes_no(never_rs)])
    print(vtable(rows, color=C.YLW, hcolor=C.YLW))
    print()


