# ── Cores ─────────────────────────────────────────────────────────────────────
class C:
    RST = "\033[0m";  BOLD = "\033[1m";  DIM = "\033[2m"
    RED = "\033[91m"; GRN  = "\033[92m"; YLW = "\033[93m"
    BLU = "\033[94m"; MAG  = "\033[95m"; CYN = "\033[96m"
    GRY = "\033[90m"; WHT  = "\033[97m"

ANSI = re.compile(r'\033\[[0-9;]*m')
def vlen(s):    return len(ANSI.sub("", str(s)))
def bold(s):    return f"{C.BOLD}{s}{C.RST}"
def green(s):   return f"{C.GRN}{s}{C.RST}"
def red(s):     return f"{C.RED}{s}{C.RST}"
def yellow(s):  return f"{C.YLW}{s}{C.RST}"
def cyan(s):    return f"{C.CYN}{s}{C.RST}"
def magenta(s): return f"{C.MAG}{s}{C.RST}"
def gray(s):    return f"{C.GRY}{s}{C.RST}"
def blue(s):    return f"{C.BLU}{s}{C.RST}"
def white(s):   return f"{C.WHT}{s}{C.RST}"
def dim(s):     return f"{C.DIM}{s}{C.RST}"
DASH = gray("—")

# ── Box Drawing ───────────────────────────────────────────────────────────────
# Estilos de box: duplo (═║╔╗╚╝╠╣╦╩╬) e simples (─│┌┐└┘├┤┬┴┼)

def box_top(widths, style="single", color=C.CYN):
    if style == "double":
        s = "╔" + "╦".join("═"*(w+2) for w in widths) + "╗"
    else:
        s = "┌" + "┬".join("─"*(w+2) for w in widths) + "┐"
    return f"{color}{C.BOLD}{s}{C.RST}"

def box_mid(widths, style="single", color=C.CYN):
    if style == "double":
        s = "╠" + "╬".join("═"*(w+2) for w in widths) + "╣"
    else:
        s = "├" + "┼".join("─"*(w+2) for w in widths) + "┤"
    return f"{color}{s}{C.RST}"

def box_sep(widths, style="single", color=C.GRY):
    s = "├" + "┼".join("─"*(w+2) for w in widths) + "┤"
    return f"{color}{s}{C.RST}"

def box_bot(widths, style="single", color=C.CYN):
    if style == "double":
        s = "╚" + "╩".join("═"*(w+2) for w in widths) + "╝"
    else:
        s = "└" + "┴".join("─"*(w+2) for w in widths) + "┘"
    return f"{color}{s}{C.RST}"

def box_row(cells, widths, vc=C.GRY, cc="│"):
    parts = []
    for i, cell in enumerate(cells):
        w   = widths[i]
        pad = " " * (w - vlen(str(cell)))
        parts.append(f" {cell}{pad} ")
    bar = f"{vc}{cc}{C.RST}"
    return bar + bar.join(parts) + bar

def vtable(rows, headers=None, color=C.CYN, hcolor=C.CYN, sep_every=0):
    """Tabela com bordas verticais e horizontais usando box-drawing."""
    all_data = ([headers] + list(rows)) if headers else list(rows)
    if not all_data: return ""
    cols   = max(len(r) for r in all_data)
    widths = [0] * cols
    for row in all_data:
        for i, cell in enumerate(row):
            widths[i] = max(widths[i], vlen(str(cell)))
    out = []
    out.append(box_top(widths, color=color))
    if headers:
        # cabeçalho com fundo destacado
        hcells = [f"{hcolor}{C.BOLD}{h}{C.RST}" for h in headers]
        # re-calcular larguras com headers originais (sem cor)
        out.append(box_row(hcells, widths, vc=hcolor))
        out.append(box_mid(widths, color=color))
    for idx, row in enumerate(rows):
        out.append(box_row(list(row), widths, vc=C.GRY))
        if sep_every and (idx+1) % sep_every == 0 and idx < len(rows)-1:
            out.append(box_sep(widths, color=C.GRY))
    out.append(box_bot(widths, color=color))
    return "\n".join(out)

# ── Helpers ───────────────────────────────────────────────────────────────────
def section(title, icon="◈", color=C.CYN):
    ic = f"{icon}  " if icon else ""
    print(f"\n{color}{C.BOLD}┌{'─'*76}┐{C.RST}")
    t = f"{ic}{title}"
    print(f"{color}{C.BOLD}│  {t:<75}│{C.RST}")
    print(f"{color}{C.BOLD}└{'─'*76}┘{C.RST}")

def fmt_speed(mbps):
    if not mbps: return DASH
    if mbps >= 1_000_000: return bold(yellow(f"{mbps//1_000_000} Tbps"))
    if mbps >= 1_000:     return bold(yellow(f"{mbps//1_000} Gbps"))
    return bold(yellow(f"{mbps} Mbps"))

def fmt_ips(ips):
    if not ips: return DASH
    first = cyan(ips[0])
    return first + (gray(f" +{len(ips)-1}") if len(ips) > 1 else "")

def yes_no(val):
    s = str(val).lower()
    if val is True  or s in ("true","yes","1"):  return f"{C.BOLD}{C.GRN} ✔ SIM {C.RST}"
    if val is False or s in ("false","no","0"): return f"{C.BOLD}{C.RED} ✘ NÃO {C.RST}"
    return DASH

def na(val): return DASH if (val is None or val=="" or val==[] or val==0) else str(val)

def fmt_date(d):
    if not d: return DASH
    try: return datetime.fromisoformat(str(d).replace("Z","+00:00")).strftime("%d/%m/%Y")
    except: return str(d)[:10]

def badge_rs(val):  return f"{C.BOLD}{C.GRN} RS  {C.RST}" if val else gray("  —  ")
def badge_bfd(val): return f"{C.BOLD}{C.CYN} BFD {C.RST}" if val else gray("  —  ")
def badge_op(val):  return f"{C.GRN}●{C.RST}" if val else f"{C.RED}●{C.RST}"

# ── HTTP ──────────────────────────────────────────────────────────────────────
def get(url, params=None, retries=MAX_RETRIES):
    headers = {"User-Agent": UA}
    if PEERINGDB_KEY and "peeringdb" in url:
        headers["Authorization"] = f"Api-Key {PEERINGDB_KEY}"
    for attempt in range(retries):
        try:
            r = requests.get(url, params=params, headers=headers, timeout=15)
            if r.status_code == 429:
                w = RETRY_DELAY*(attempt+1)
                print(yellow(f"  ⏳ Rate limit {w}s...")); time.sleep(w); continue
            if r.status_code in (404, 500, 502, 503, 504): return None
            r.raise_for_status()
            return r.json()
        except requests.exceptions.ConnectionError:
            if attempt < retries-1: time.sleep(RETRY_DELAY)
        except requests.exceptions.Timeout:
            if attempt < retries-1: time.sleep(RETRY_DELAY)
        except Exception:
            break
    return None

